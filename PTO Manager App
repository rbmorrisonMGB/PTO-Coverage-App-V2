            html += `<td style="background:var(--surface);border:0.5px solid var(--border);padding:5px;text-align:center;color:#d1cfc8;font-size:14px">–</td>`;
          }
        });

        // Coverage column
        html += `<td style="background:var(--surface2);border:0.5px solid var(--border);padding:6px 8px;vertical-align:middle">`;
        if (rd.coverers.length === 0) {
          html += `<span style="font-size:11px;color:var(--text3);font-style:italic">No coverage assigned</span>`;
        } else {
          rd.coverers.forEach(cov => {
            const pillBg = cov.role === 'Primary' ? '#eff6ff' : '#fffbeb';
            const pillColor = cov.role === 'Primary' ? '#1e3a8a' : '#92400e';
            html += `<div style="display:flex;align-items:center;gap:5px;margin-bottom:3px">
              <span style="font-size:10px;font-weight:500;padding:1px 6px;border-radius:999px;background:${pillBg};color:${pillColor};white-space:nowrap">${cov.role}</span>
              <span style="font-size:11px;color:var(--text)">${cov.name}</span>
