  });
  const archivedAssignments = coverageAssignments.filter(a => {
    const req = reqById(a.ptoRequestId);
    return !req || req.endDate < today;
  });

  const roles = ['Primary', 'Secondary', 'Additional'];

  function buildGroupedRows(assignments, isArchive) {
    if (assignments.length === 0) return null;
    const grouped = {};
