  }).join(', ');

  document.getElementById('edit-dates-sub').innerHTML =
    `<strong>${m?.name || 'Unknown'}</strong> &nbsp;·&nbsp; Current dates: ${req.startDate} → ${req.endDate}` +
    (covererNames ? ` &nbsp;·&nbsp; Coverers: ${covererNames}` : '');
  document.getElementById('edit-start-date').value = req.startDate;
  document.getElementById('edit-end-date').value = req.endDate;
  document.getElementById('edit-dates-preview').innerHTML = '';
  document.getElementById('edit-dates-confirm-btn').disabled = true;
  document.getElementById('edit-dates-modal').classList.add('open');
  previewEditDates();
}

function previewEditDates() {
  const req = reqById(_editDatesReqId);
  if (!req) return;
  const newStart = document.getElementById('edit-start-date').value;
  const newEnd   = document.getElementById('edit-end-date').value;
  const confirmBtn = document.getElementById('edit-dates-confirm-btn');
  const preview = document.getElementById('edit-dates-preview');

  if (!newStart || !newEnd) { preview.innerHTML = ''; confirmBtn.disabled = true; return; }
  if (newEnd < newStart) {
    preview.innerHTML = `<div class="error-banner">End date must be after start date.</div>`;
    confirmBtn.disabled = true; return;
  }
  if (newStart === req.startDate && newEnd === req.endDate) {
    preview.innerHTML = `<div class="info-banner">Dates are unchanged from the original request.</div>`;
    confirmBtn.disabled = true; return;
  }

  // Check each existing coverer for conflicts on the NEW dates
  const assigns = coverageAssignments.filter(a => a.ptoRequestId === req.id);
  const conflicting = [];
  const keeping = [];

  assigns.forEach((a, idx) => {
    const coverer = memberById(a.covererId);
    if (!coverer) return;
    const role = idx === 0 ? 'Primary' : 'Secondary';
    // On PTO same dates?
    const onPTO = ptoRequests.some(r =>
      r.status === 'Approved' && r.memberId === a.covererId &&
      r.id !== req.id && dateRangesOverlap(r.startDate, r.endDate, newStart, newEnd)
    );
    // Covering someone else same dates?
    const coveringOther = coverageAssignments.some(x =>
      x.covererId === a.covererId && x.ptoRequestId !== req.id && (() => {
        const xReq = reqById(x.ptoRequestId);
        return xReq && dateRangesOverlap(xReq.startDate, xReq.endDate, newStart, newEnd);
      })()
    );
    // On leave?
    const onLeave = isMemberUnavailableForRange(coverer, newStart, newEnd);
    if (onPTO || coveringOther || onLeave) {
      conflicting.push({ coverer, role, reason: onPTO ? 'on PTO' : onLeave ? 'on leave' : 'already covering someone else' });
    } else {
      keeping.push({ coverer, role });
    }
  });

  _editDatesConflictingCoverers = conflicting;
  _editDatesKeepCoverers = conflicting.length === 0;

  const fmtDate = ds => new Date(ds + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

  if (conflicting.length === 0) {
    // All coverers available — keep them
    preview.innerHTML = `
      <div style="background:var(--success-soft);border:1px solid #9FE1CB;border-radius:var(--radius-sm);padding:0.85rem 1rem;font-size:0.875rem;color:var(--success);margin-bottom:0.75rem">
        <strong>✅ No conflicts found</strong><br>
        <span style="font-size:0.82rem">All current coverers are available ${fmtDate(newStart)}–${fmtDate(newEnd)}. Coverage will remain the same.</span>
        <div style="margin-top:0.5rem">
          ${keeping.map(k => `<div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:0.8rem">
            <span>${k.coverer.name} <span style="color:var(--success);opacity:0.7">(${k.role})</span></span>
            <span style="background:#c4edd9;color:#085041;border-radius:999px;padding:1px 8px;font-size:0.72rem;font-weight:600">Kept</span>
          </div>`).join('')}
        </div>
      </div>`;
    confirmBtn.disabled = false;
  } else {
    // Some coverers conflict
    preview.innerHTML = `
      <div style="background:var(--pending-soft);border:1px solid #FAC775;border-radius:var(--radius-sm);padding:0.85rem 1rem;font-size:0.875rem;color:var(--pending);margin-bottom:0.75rem">
        <strong>⚠️ Coverer conflict on new dates</strong><br>
        <span style="font-size:0.82rem">The following coverers are unavailable ${fmtDate(newStart)}–${fmtDate(newEnd)}. They will be replaced automatically.</span>
        <div style="margin-top:0.6rem">
          ${conflicting.map(c => `<div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:0.8rem">
            <span>${c.coverer.name} <span style="opacity:0.7">(${c.role})</span></span>
            <span style="background:#fce8e6;color:#BC343E;border-radius:999px;padding:1px 8px;font-size:0.72rem;font-weight:600">Replaced — ${c.reason}</span>
          </div>`).join('')}
          ${keeping.map(k => `<div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:0.8rem">
            <span>${k.coverer.name} <span style="opacity:0.7">(${k.role})</span></span>
            <span style="background:#c4edd9;color:#085041;border-radius:999px;padding:1px 8px;font-size:0.72rem;font-weight:600">No conflict — kept</span>
          </div>`).join('')}
          <div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;font-size:0.8rem;color:var(--info)">
            <span>${conflicting.length} new coverer${conflicting.length > 1 ? 's' : ''} will be auto-assigned</span>
            <span style="background:var(--info-soft);color:var(--info);border-radius:999px;padding:1px 8px;font-size:0.72rem;font-weight:600">New</span>
          </div>
        </div>
      </div>`;
    confirmBtn.disabled = false;
  }
}

function confirmEditDates() {
  const req = reqById(_editDatesReqId);
  if (!req) return;
  const newStart = document.getElementById('edit-start-date').value;
  const newEnd   = document.getElementById('edit-end-date').value;
  if (!newStart || !newEnd || newEnd < newStart) return;

  const oldStart = req.startDate;
  const oldEnd   = req.endDate;

  // Save change log entry
  if (!req.changeLog) req.changeLog = [];
  const keepNames = _editDatesConflictingCoverers.length === 0
    ? coverageAssignments.filter(a => a.ptoRequestId === req.id).map(a => memberById(a.covererId)?.name || '').filter(Boolean).join(', ')
    : null;
  req.changeLog.unshift({
    date: new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
    from: `${oldStart} → ${oldEnd}`,
    to:   `${newStart} → ${newEnd}`,
    note: keepNames ? `Coverage kept: ${keepNames}` : `${_editDatesConflictingCoverers.length} coverer(s) replaced`
  });

  // Update dates
  req.startDate = newStart;
  req.endDate   = newEnd;

  // Strip assignments and regenerate — replaceConflictingCoverers handles keeping valid ones
  coverageAssignments = coverageAssignments.filter(a => a.ptoRequestId !== req.id);
  // Re-add only the non-conflicting coverers directly
  if (_editDatesKeepCoverers) {
    // All coverers valid — keep them, just update if needed
    coverageAssignments = generateCoverageAssignments(ptoRequests, coverageAssignments, teamMembers, req.override || false, false, false);
  } else {
    // Strip all, regenerate fresh
    coverageAssignments = generateCoverageAssignments(ptoRequests, coverageAssignments, teamMembers, req.override || false, false, false);
  }
  // Run conflict replacement to handle edge cases
  coverageAssignments = replaceConflictingCoverers(ptoRequests, coverageAssignments, teamMembers);

  saveAll();
  renderAll();
  closeEditDatesModal();
  showToast(`✅ PTO dates updated: ${newStart} → ${newEnd}. Coverage reassigned.`);
}

function closeEditDatesModal() {
  document.getElementById('edit-dates-modal').classList.remove('open');
  _editDatesReqId = null;
  _editDatesConflictingCoverers = [];
}
