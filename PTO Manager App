// STATE HELPERS
// ============================================================
function memberById(id) { return teamMembers.find(m => m.id === id); }
function reqById(id) { return ptoRequests.find(r => r.id === id); }

function canApproveRequest(request) {
  if (request.override) return { allowed: true };
  if (isInBlackout(request.startDate, request.endDate)) return { allowed: false, reason: 'blackout' };
  const weeks = getWeekKeysForRange(request.startDate, request.endDate);
  for (const week of weeks) {
    // Count both Approved AND Pending requests toward the cap — prevents sneaking
    // in extras by submitting multiple Pending requests before approving them
    const out = ptoRequests.filter(r =>
      (r.status === 'Approved' || r.status === 'Pending') &&
      r.id !== request.id &&
      getWeekKeysForRange(r.startDate, r.endDate).includes(week)
    ).length;
    if (out + 1 > 5) return { allowed: false, week };
  }
  return { allowed: true };
}

// ============================================================
// SELF-HEAL: Fix any under-covered approved requests on load
// ============================================================
function healUnderCoveredRequests() {
  const approved = ptoRequests.filter(r => r.status === 'Approved');
  let healed = 0;
  approved.forEach(req => {
    const days = numberBusinessDays(req.startDate, req.endDate);
    const needed = days >= 3 ? 2 : 1;
    const existing = coverageAssignments.filter(a => a.ptoRequestId === req.id && !a.isOverrideExtra);
    if (existing.length < needed) {
      // Strip ALL assignments for this request and do a full fresh reassignment
      coverageAssignments = coverageAssignments.filter(a => a.ptoRequestId !== req.id);
      const fresh = generateCoverageAssignments(
        ptoRequests, coverageAssignments, teamMembers, req.override || false, false, false
      );
      coverageAssignments = fresh;
      healed++;
    }
  });
  if (healed > 0) saveAll();
}
