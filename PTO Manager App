let _reassignPtoId = null;

function openReassignModal(ptoReqId) {
  const req = reqById(ptoReqId);
  if (!req) return;
  _reassignPtoId = ptoReqId;

  const requester = memberById(req.memberId);
  const days = numberBusinessDays(req.startDate, req.endDate);
  document.getElementById('reassign-pto-info').innerHTML =
    `<strong>${requester?.name || 'Unknown'}</strong> &nbsp;|&nbsp; ${req.type} &nbsp;|&nbsp; ${req.startDate} – ${req.endDate} &nbsp;|&nbsp; ${days} business day${days !== 1 ? 's' : ''}`;

  // Get current coverers for this request
  const existing = coverageAssignments.filter(a => a.ptoRequestId === ptoReqId);
  const primaryId = existing[0]?.covererId || '';
  const secondaryId = existing[1]?.covererId || '';

  // Build options — mark members on PTO or unavailable during these dates
  const onPTOIds = new Set(
    ptoRequests
      .filter(r => r.status === 'Approved' && r.id !== ptoReqId && dateRangesOverlap(r.startDate, r.endDate, req.startDate, req.endDate))
      .map(r => r.memberId)
  );

  function buildOpts(includeNone) {
    const opts = teamMembers
      .filter(m => m.id !== req.memberId)
      .map(m => {
        const onPTO = onPTOIds.has(m.id);
        const unavail = isMemberUnavailableForRange(m, req.startDate, req.endDate);
        const excluded = isCoverageExcluded(m);
        let label = m.name;
        if (onPTO) label += ' ⚠ (on PTO)';
        else if (unavail) label += ' ⚠ (unavailable)';
        else if (excluded) label += ' ⚠ (excluded)';
        return `<option value="${m.id}">${label}</option>`;
      })
      .join('');
    return (includeNone ? `<option value="">— None —</option>` : '') + opts;
  }

  document.getElementById('reassign-primary').innerHTML = buildOpts(false);
  document.getElementById('reassign-secondary').innerHTML = buildOpts(true);

  if (primaryId) document.getElementById('reassign-primary').value = primaryId;
  if (secondaryId) document.getElementById('reassign-secondary').value = secondaryId;
  else document.getElementById('reassign-secondary').value = '';

  document.getElementById('reassign-warnings').style.display = 'none';
  document.getElementById('reassign-override').checked = false;
  document.getElementById('reassign-save-btn').disabled = false;
  document.getElementById('reassign-modal').classList.add('open');

  // Run validation immediately so warnings show on open if existing coverers already violate rules
  validateReassign();
}

function closeReassignModal() {
  document.getElementById('reassign-modal').classList.remove('open');
  _reassignPtoId = null;
}

function checkCovererViolations(memberId, ptoReqId) {
  const violations = [];
  const req = reqById(ptoReqId);
  if (!req) return violations;
  const member = memberById(memberId);
  if (!member) return violations;

  if (member.id === req.memberId)
    violations.push('This person is the one taking PTO — they cannot cover themselves.');

  const onPTO = ptoRequests.some(r =>
    r.status === 'Approved' && r.memberId === memberId && r.id !== ptoReqId &&
    dateRangesOverlap(r.startDate, r.endDate, req.startDate, req.endDate)
  );
  if (onPTO) violations.push('This person is on approved PTO during the same dates.');

  if (isMemberUnavailableForRange(member, req.startDate, req.endDate))
    violations.push('This person is marked unavailable for coverage during these dates.');

  if (isCoverageExcluded(member))
    violations.push('This person is on the coverage exclusion list.');

  const otherAssignments = coverageAssignments.filter(a => a.ptoRequestId !== ptoReqId);
  if (hasCoverageInSameOrAdjacentMonth(memberId, req, otherAssignments, ptoRequests))
    violations.push('This person is already assigned coverage in the same or adjacent month.');

  return violations;
}

function validateReassign() {
  if (!_reassignPtoId) return;
  const primaryId = parseInt(document.getElementById('reassign-primary').value);
  const secondaryVal = document.getElementById('reassign-secondary').value;
  const secondaryId = secondaryVal ? parseInt(secondaryVal) : null;

  const allViolations = [];
  if (primaryId) checkCovererViolations(primaryId, _reassignPtoId).forEach(m => allViolations.push(`Primary — ${m}`));
  if (secondaryId) checkCovererViolations(secondaryId, _reassignPtoId).forEach(m => allViolations.push(`Secondary — ${m}`));
  if (primaryId && secondaryId && primaryId === secondaryId)
    allViolations.push('Primary and Secondary coverer cannot be the same person.');

  const warningsEl = document.getElementById('reassign-warnings');
  const warningList = document.getElementById('reassign-warning-list');
  const overrideChecked = document.getElementById('reassign-override').checked;
  const saveBtn = document.getElementById('reassign-save-btn');

  if (allViolations.length > 0) {
    warningsEl.style.display = 'block';
    warningList.innerHTML = allViolations.map(v => `<li>${v}</li>`).join('');
    saveBtn.disabled = !overrideChecked;
  } else {
    warningsEl.style.display = 'none';
    warningList.innerHTML = '';
    saveBtn.disabled = false;
  }
}

function saveReassign() {
  if (!_reassignPtoId) return;
  const req = reqById(_reassignPtoId);
  if (!req) return;

  const primaryId = parseInt(document.getElementById('reassign-primary').value);
  const secondaryVal = document.getElementById('reassign-secondary').value;
  const secondaryId = secondaryVal ? parseInt(secondaryVal) : null;

  if (!primaryId) { showError('Please select a Primary coverer.'); return; }

  // Remove existing assignments for this request only
  coverageAssignments = coverageAssignments.filter(a => a.ptoRequestId !== _reassignPtoId);

  let nid = coverageAssignments.reduce((max, a) => Math.max(max, a.id), 0) + 1;
  const days = numberBusinessDays(req.startDate, req.endDate);

  coverageAssignments.push({
    id: nid++, ptoRequestId: _reassignPtoId, covererId: primaryId,
    rule: 'Manual assignment (Primary)', scoreImpact: days >= 3 ? 1.5 : 1, isOverrideExtra: false
  });

  if (secondaryId) {
    coverageAssignments.push({
      id: nid++, ptoRequestId: _reassignPtoId, covererId: secondaryId,
      rule: 'Manual assignment (Secondary)', scoreImpact: days >= 3 ? 1.5 : 1, isOverrideExtra: false
    });
  }

  saveAll();
  renderAll();
  closeReassignModal();
  showToast('✅ Coverage manually reassigned.');
}

