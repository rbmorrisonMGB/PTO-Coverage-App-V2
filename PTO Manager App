        } else {
          const actionBtns = idx === 0
            ? `<button class="btn btn-secondary btn-sm" onclick="openReassignModal(${req.id})">✏️ Reassign</button>
               <button class="btn btn-danger btn-sm" onclick="removeCoverage(${a.id})">Remove</button>`
            : `<button class="btn btn-danger btn-sm" onclick="removeCoverage(${a.id})">Remove</button>`;

          html += `<tr>
            <td style="font-family:'DM Mono',monospace;font-size:0.8rem">#${a.id}</td>
