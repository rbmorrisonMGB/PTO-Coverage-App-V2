  }

  // --- Active assignments ---
  const tbody = document.getElementById('coverage-tbody');
  const activeHtml = buildGroupedRows(activeAssignments, false);
  tbody.innerHTML = activeHtml || '<tr class="empty-row"><td colspan="7">No active coverage assignments. Approve PTO requests and use Auto-Assign.</td></tr>';

