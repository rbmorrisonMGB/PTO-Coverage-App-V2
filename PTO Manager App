function countBusinessDays(startDate, endDate) {
  if (!startDate || !endDate) return 0;
  const FEDERAL_HOLIDAYS = [
    '2026-01-01','2026-01-19','2026-02-16','2026-05-25',
    '2026-06-19','2026-07-04','2026-09-07','2026-10-12',
    '2026-11-11','2026-11-26','2026-12-25'
  ];
  let count = 0;
  const start = new Date(startDate + 'T00:00:00');
  const end   = new Date(endDate   + 'T00:00:00');
  const cur   = new Date(start);
  while (cur <= end) {
    const day = cur.getUTCDay();
    const ds  = cur.toISOString().split('T')[0];
    if (day !== 0 && day !== 6 && !FEDERAL_HOLIDAYS.includes(ds)) count++;
    cur.setUTCDate(cur.getUTCDate() + 1);
  }
  return count;
}

function buildPTOTrackerData() {
  const currentYear = new Date().getFullYear().toString();
  const today = new Date();
  const curMonth = today.getMonth();
  const curYear  = today.getFullYear();

  const windowMonths = [];
  for (let i = -3; i <= 2; i++) {
    let m = curMonth + i, y = curYear;
    if (m < 0)  { m += 12; y--; }
    if (m > 11) { m -= 12; y++; }
    windowMonths.push({ month: m, year: y });
  }

  const approvedReqs = ptoRequests.filter(r => r.status === 'Approved');

  return teamMembers.map(member => {
    const reqs = approvedReqs.filter(r => r.memberId === member.id);
    const yearly = { Vacation: 0, Medical: 0, Personal: 0, Unpaid: 0 };
    reqs.forEach(r => {
      if (r.startDate.startsWith(currentYear) || r.endDate.startsWith(currentYear)) {
        const days = countBusinessDays(r.startDate, r.endDate);
        if (yearly[r.type] !== undefined) yearly[r.type] += days;
        else yearly.Vacation += days;
      }
    });

    const monthDays = windowMonths.map(({ month, year }) => {
      const monthStart = `${year}-${String(month + 1).padStart(2, '0')}-01`;
      const lastDay = new Date(year, month + 1, 0).getDate();
      const monthEnd = `${year}-${String(month + 1).padStart(2, '0')}-${String(lastDay).padStart(2, '0')}`;
      let days = 0;
      reqs.forEach(r => {
        if (dateRangesOverlap(r.startDate, r.endDate, monthStart, monthEnd)) {
          const s = r.startDate > monthStart ? r.startDate : monthStart;
          const e = r.endDate   < monthEnd   ? r.endDate   : monthEnd;
          days += countBusinessDays(s, e);
        }
      });
      return days;
    });

    return { member, yearly, monthDays, windowMonths };
  });
}

