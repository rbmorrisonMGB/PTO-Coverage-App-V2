    });
    html += `<td style="background:var(--surface2);border:0.5px solid var(--border)"></td></tr>`;

    // Find which requests have any PTO day in this week
    const weekDates = week.map(d => d.toISOString().split('T')[0]);
    const activeReqs = Object.values(reqData).filter(rd =>
      weekDates.some(ds => rd.ptoDates.has(ds))
