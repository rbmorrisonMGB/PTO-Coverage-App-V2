// ============================================================
// DATE UTILS
// ============================================================
function toDate(str) { return new Date(str + 'T00:00:00'); }

function dateRangesOverlap(aS, aE, bS, bE) {
  return toDate(aS) <= toDate(bE) && toDate(bS) <= toDate(aE);
}

function getFederalHolidays(year) {
  function nthMonday(month, n) {
    const d = new Date(Date.UTC(year, month, 1));
    let cnt = 0;
    while (true) { if (d.getUTCDay() === 1) { cnt++; if (cnt === n) return d; } d.setUTCDate(d.getUTCDate() + 1); }
  }
  function lastMonday(month) {
    const d = new Date(Date.UTC(year, month + 1, 0));
    while (d.getUTCDay() !== 1) d.setUTCDate(d.getUTCDate() - 1);
    return d;
  }
  function thanksGiving() {
    const d = new Date(Date.UTC(year, 10, 1)); let nth = 0;
    while (true) { if (d.getUTCDay() === 4) { nth++; if (nth === 4) return new Date(d); } d.setUTCDate(d.getUTCDate() + 1); }
  }
  return [
    new Date(Date.UTC(year, 0, 1)), nthMonday(0, 3), nthMonday(1, 3), lastMonday(4),
    new Date(Date.UTC(year, 5, 19)), new Date(Date.UTC(year, 6, 4)),
    nthMonday(8, 1), nthMonday(9, 2), new Date(Date.UTC(year, 10, 11)),
    thanksGiving(), new Date(Date.UTC(year, 11, 25))
  ].map(d => d.toISOString().split('T')[0]);
}

function isFederalHoliday(dateStr) {
  const year = toDate(dateStr).getUTCFullYear();
  return getFederalHolidays(year).includes(dateStr);
}

function numberBusinessDays(startDate, endDate) {
  const s = toDate(startDate), e = toDate(endDate);
  let cnt = 0, cur = new Date(s);
  while (cur <= e) {
    const day = cur.getUTCDay(), ds = cur.toISOString().split('T')[0];
    if (day >= 1 && day <= 5 && !isFederalHoliday(ds)) cnt++;
    cur.setUTCDate(cur.getUTCDate() + 1);
  }
  return cnt;
}

function getBlackoutRanges(year) {
  return ['02-05', '06-05', '10-05'].map(mday => {
    const [m, d] = mday.split('-').map(Number);
    const target = new Date(Date.UTC(year, m - 1, d));
    const start = new Date(target); start.setUTCDate(target.getUTCDate() - 7);
    const end = new Date(target); end.setUTCDate(target.getUTCDate() - 1);
    return { start: start.toISOString().split('T')[0], end: end.toISOString().split('T')[0] };
  });
}

function isInBlackout(startDate, endDate) {
  const year = toDate(startDate).getUTCFullYear();
  return getBlackoutRanges(year).some(r => dateRangesOverlap(startDate, endDate, r.start, r.end));
}

function getWeekKey(dateStr) {
  const d = toDate(dateStr), day = d.getDay();
  const mon = new Date(d); mon.setDate(d.getDate() - ((day + 6) % 7));
  return mon.toISOString().split('T')[0];
}

function getWeekKeysForRange(startDate, endDate) {
  const keys = new Set(), cur = toDate(startDate), end = toDate(endDate);
  while (cur <= end) { keys.add(getWeekKey(cur.toISOString().split('T')[0])); cur.setDate(cur.getDate() + 1); }
  return Array.from(keys);
}

function getMonthKey(dateStr) {
  const d = toDate(dateStr);
  return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}`;
}

function getMonthOrdinal(dateStr) {
  const d = toDate(dateStr); return d.getUTCFullYear() * 12 + d.getUTCMonth();
}

function getMonthKeysBetween(startDate, endDate) {
  const keys = new Set(), cur = toDate(startDate), end = toDate(endDate);
  cur.setUTCDate(1); end.setUTCDate(1);
  while (cur <= end) {
    keys.add(`${cur.getUTCFullYear()}-${String(cur.getUTCMonth() + 1).padStart(2, '0')}`);
    cur.setUTCMonth(cur.getUTCMonth() + 1);
  }
  return Array.from(keys);
}

// ============================================================
// COVERAGE LOGIC
// ============================================================
function isCoverageExcluded(member) {
  const excluded = new Set(['juliana mcwilliams', 'mcwilliams, juliana']);
  return excluded.has((member.name || '').trim().toLowerCase());
}

function isMemberUnavailableForRange(member, startDate, endDate) {
  if (!member) return true;
  if (member.isCoverageAvailable !== false) return false;
  if (!member.coverageLeaveStart || !member.coverageLeaveEnd) return true;
  return dateRangesOverlap(startDate, endDate, member.coverageLeaveStart, member.coverageLeaveEnd);
}

function hasCoverageInMonth(memberId, monthKey, assignments, requests, skipId) {
  return assignments.some(a => {
    if (a.id === skipId) return false;
    if (a.covererId !== memberId) return false;
    const req = requests.find(r => r.id === a.ptoRequestId);
    if (!req) return false;
    return getMonthKeysBetween(req.startDate, req.endDate).includes(monthKey);
  });
}

function hasCoverageInSameOrAdjacentMonth(memberId, pto, assignments, requests) {
  const ord = getMonthOrdinal(pto.startDate);
  return assignments.some(a => {
    if (a.covererId !== memberId) return false;
    const req = requests.find(r => r.id === a.ptoRequestId);
    if (!req) return false;
    for (let m = getMonthOrdinal(req.startDate); m <= getMonthOrdinal(req.endDate); m++) {
      if (Math.abs(m - ord) <= 1) return true;
    }
    return false;
  });
}

function coverageDaysInWindow(memberId, assignments, requests, refStr) {
  const ref = toDate(refStr);
  const ws = new Date(ref); ws.setMonth(ws.getMonth() - 3);
  const we = new Date(ref); we.setMonth(we.getMonth() + 3);
  let total = 0;
  assignments.forEach(a => {
    if (a.covererId !== memberId) return;
    const req = requests.find(r => r.id === a.ptoRequestId);
    if (!req) return;
    const rs = toDate(req.startDate), re = toDate(req.endDate);
    const os = rs > ws ? rs : ws, oe = re < we ? re : we;
    if (os <= oe) total += numberBusinessDays(os.toISOString().split('T')[0], oe.toISOString().split('T')[0]);
  });
  return total;
}

function calculateScore(members, requests, assignments, mode, refStr) {
  const scores = {};
  members.forEach(m => { scores[m.id] = coverageDaysInWindow(m.id, assignments, requests, refStr); });
  if (mode === 'weighted') {
    assignments.forEach(a => {
      const req = requests.find(r => r.id === a.ptoRequestId);
      if (req) scores[req.memberId] = (scores[req.memberId] || 0) + 0.25;
    });
    requests.forEach(r => {
      if (r.status === 'Approved') scores[r.memberId] = (scores[r.memberId] || 0) - 0.1;
    });
  }
  return members.map(m => ({ id: m.id, name: m.name, score: Math.max(0, parseFloat((scores[m.id] || 0).toFixed(2))) }));
}

function selectCoverersForPTO(pto, requests, assignments, members, count, allowOverride) {
  const scores = calculateScore(members, requests, assignments, 'days', new Date().toISOString().split('T')[0]);
  const absentIds = requests.filter(r => r.status === 'Approved' && dateRangesOverlap(r.startDate, r.endDate, pto.startDate, pto.endDate)).map(r => r.memberId);

  // Base eligible: not the requester, not on PTO same dates, not excluded, not on leave
  const eligible = members.filter(m =>
    m.id !== pto.memberId && !absentIds.includes(m.id) && !isCoverageExcluded(m) && !isMemberUnavailableForRange(m, pto.startDate, pto.endDate)
  );
  if (eligible.length === 0) return [];

  // Always exclude anyone already covering someone else during the same date range
  // This is a hard rule that cannot be overridden by fallback
  const notDoubleBooked = eligible.filter(m =>
    !assignments.some(a => {
      if (a.covererId !== m.id) return false;
      const r = requests.find(r => r.id === a.ptoRequestId);
      return r && r.id !== pto.id && dateRangesOverlap(r.startDate, r.endDate, pto.startDate, pto.endDate);
    })
  );

  // Try adjacent-month filtered pool first
  let pool = notDoubleBooked.filter(m => !hasCoverageInSameOrAdjacentMonth(m.id, pto, assignments, requests));

  // Fall back to notDoubleBooked (same-week exclusion still applies) if pool too small
  if (pool.length < count) pool = notDoubleBooked;

  // Further fall back to full eligible only if still not enough
  if (pool.length < count) pool = eligible;

  // Prefer coverers not yet assigned to anything (fresh)
  const assigned = new Set(assignments.map(a => a.covererId));
  const fresh = pool.filter(m => !assigned.has(m.id));
  if (fresh.length >= count) pool = fresh;

  pool.sort((a, b) => (scores.find(x => x.id === a.id)?.score || 0) - (scores.find(x => x.id === b.id)?.score || 0));

  // Ensure we never return duplicates
  const result = [];
  const used = new Set();
  for (const m of pool) {
    if (result.length >= count) break;
    if (!used.has(m.id)) { result.push(m.id); used.add(m.id); }
  }
  return result;
}

function replaceConflictingCoverers(requests, assignments, members) {
  const resolved = assignments.map(a => ({ ...a }));
  resolved.forEach((a, idx) => {
    const req = requests.find(r => r.id === a.ptoRequestId);
    if (!req) return;
    const coverer = members.find(m => m.id === a.covererId);
    const conflict = requests.some(r => r.status === 'Approved' && r.memberId === a.covererId && dateRangesOverlap(r.startDate, r.endDate, req.startDate, req.endDate));
    const unavail = isMemberUnavailableForRange(coverer, req.startDate, req.endDate);
    if (!conflict && !unavail) return;
    const scores = calculateScore(members, requests, resolved, 'days', new Date().toISOString().split('T')[0]);
    // Already-assigned coverer IDs in the current resolved set (excluding this slot)
    const alreadyCovering = new Set(resolved.filter((_,i)=>i!==idx).map(x=>x.covererId));
    const candidates = members.filter(m =>
      m.id !== req.memberId &&
      m.id !== a.covererId &&
      !isCoverageExcluded(m) &&
      !isMemberUnavailableForRange(m, req.startDate, req.endDate) &&
      // Not on PTO same dates
      !requests.some(r => r.status === 'Approved' && r.memberId === m.id && dateRangesOverlap(r.startDate, r.endDate, req.startDate, req.endDate)) &&
      // Not already covering someone else this same week
      !resolved.some(x => x.covererId === m.id && x.ptoRequestId !== req.id && (() => {
        const xReq = requests.find(r => r.id === x.ptoRequestId);
        return xReq && dateRangesOverlap(xReq.startDate, xReq.endDate, req.startDate, req.endDate);
      })()) &&
      // Use adjacent-month check (same rule as selectCoverersForPTO)
      !hasCoverageInSameOrAdjacentMonth(m.id, req, resolved.filter((_,i)=>i!==idx), requests)
    );
    if (candidates.length === 0) return;
    candidates.sort((a2, b) => (scores.find(x => x.id === a2.id)?.score || 0) - (scores.find(x => x.id === b.id)?.score || 0));
    resolved[idx] = { ...a, covererId: candidates[0].id, rule: a.rule + (unavail ? ' (replaced: leave)' : ' (replaced: PTO)') };
  });
  return resolved;
}

function generateCoverageAssignments(requests, assignments, members, allowOverride, includeExisting, extraPerRequest) {
  const toAssign = requests.filter(req => {
    if (req.status !== 'Approved') return false;
    if (extraPerRequest) return !assignments.some(a => a.ptoRequestId === req.id && a.isOverrideExtra);
    if (includeExisting) return true;
    // Include if no assignments exist, OR if existing count is less than what's needed
    // This fixes the case where a request was previously under-assigned (e.g. 1 coverer
    // assigned for a 3+ day PTO that should have 2)
    const existing = assignments.filter(a => a.ptoRequestId === req.id);
    if (existing.length === 0) return true;
    const days = numberBusinessDays(req.startDate, req.endDate);
    const needed = days >= 3 ? 2 : 1;
    return existing.length < needed;
  });
  const newOnes = [];
  let nid = assignments.reduce((max, a) => Math.max(max, a.id), 0) + 1;
  toAssign.forEach(req => {
    const days = numberBusinessDays(req.startDate, req.endDate);
    const needed = extraPerRequest ? 1 : (days >= 3 ? 2 : 1);
    // Only add the number of coverers still missing, not all needed
    const alreadyAssigned = assignments.filter(a => a.ptoRequestId === req.id).length;
    const stillNeeded = extraPerRequest ? 1 : Math.max(0, needed - alreadyAssigned);
    if (stillNeeded === 0) return;
    const pool = [...assignments, ...newOnes];
    const selected = selectCoverersForPTO(req, requests, pool, members, stillNeeded, allowOverride);
    selected.forEach(cid => {
      newOnes.push({ id: nid++, ptoRequestId: req.id, covererId: cid, rule: days >= 3 ? 'Multi-day (≥3 biz days)' : 'Short PTO single coverer', scoreImpact: days >= 3 ? 1.5 : 1, isOverrideExtra: !!extraPerRequest });
    });
  });
  return replaceConflictingCoverers(requests, [...assignments, ...newOnes], members);
}

