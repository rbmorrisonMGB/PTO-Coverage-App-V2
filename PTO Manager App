    const barColor = total === 0 ? 'var(--border)' : total <= 5 ? '#9FE1CB' : total <= 10 ? '#01828E' : '#016B76';
    const cell = (val, bg, tx) => val > 0
      ? `<span style="background:${bg};color:${tx};border-radius:4px;padding:2px 6px;font-size:0.75rem;font-weight:500">${val}</span>`
      : `<span style="color:var(--text3)">—</span>`;
    return `<tr>
      <td style="padding:7px 10px;border-bottom:1px solid var(--border)">
        <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:${member.managerColor};margin-right:6px;vertical-align:middle"></span>${member.name}
      </td>
      <td style="padding:7px 10px;border-bottom:1px solid var(--border);font-size:0.78rem;color:var(--text3)">${member.manager.split(',')[0]}</td>
      <td style="padding:7px 10px;border-bottom:1px solid var(--border);text-align:center">${cell(yearly.Vacation,'#E6F1FB','#0C447C')}</td>
      <td style="padding:7px 10px;border-bottom:1px solid var(--border);text-align:center">${cell(yearly.Medical,'#FAEEDA','#633806')}</td>
      <td style="padding:7px 10px;border-bottom:1px solid var(--border);text-align:center">${cell(yearly.Personal,'#EAF3DE','#27500A')}</td>
      <td style="padding:7px 10px;border-bottom:1px solid var(--border);text-align:center">${cell(yearly.Unpaid,'#FCEBEB','#791F1F')}</td>
