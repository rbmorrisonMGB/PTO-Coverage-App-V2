function renderYearlyTable(sortCol) {
  _yearlySortCol = sortCol;
  const data = buildPTOTrackerData();
  data.sort((a, b) => {
    if (sortCol === 'name')  return a.member.name.localeCompare(b.member.name);
    if (sortCol === 'total') return (b.yearly.Vacation+b.yearly.Medical+b.yearly.Personal+b.yearly.Unpaid) - (a.yearly.Vacation+a.yearly.Medical+a.yearly.Personal+a.yearly.Unpaid);
    if (sortCol === 'vac')   return b.yearly.Vacation - a.yearly.Vacation;
    return 0;
  });

  const totalTeamDays = data.reduce((s, d) => s + d.yearly.Vacation + d.yearly.Medical + d.yearly.Personal + d.yearly.Unpaid, 0);
  const statEl = document.getElementById('tracker-stat-total');
  if (statEl) statEl.textContent = totalTeamDays;

  const maxDays = Math.max(1, ...data.map(d => d.yearly.Vacation + d.yearly.Medical + d.yearly.Personal + d.yearly.Unpaid));
  const tbody = document.getElementById('tracker-yearly-body');
  if (!tbody) return;

  tbody.innerHTML = data.map(({ member, yearly }) => {
    const total = yearly.Vacation + yearly.Medical + yearly.Personal + yearly.Unpaid;
