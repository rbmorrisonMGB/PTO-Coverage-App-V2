function fixUnderCoveredRequests() {
  const approved = ptoRequests.filter(r => r.status === 'Approved');
  let fixed = 0;
  approved.forEach(req => {
    const days = numberBusinessDays(req.startDate, req.endDate);
    const needed = days >= 3 ? 2 : 1;
    const existing = coverageAssignments.filter(a => a.ptoRequestId === req.id && !a.isOverrideExtra);
    if (existing.length < needed) {
      coverageAssignments = coverageAssignments.filter(a => a.ptoRequestId !== req.id);
      coverageAssignments = generateCoverageAssignments(ptoRequests, coverageAssignments, teamMembers, req.override || false, false, false);
      fixed++;
    }
  });
  saveAll();
  renderAll();
  if (fixed > 0) showToast('✅ Fixed ' + fixed + ' under-covered request' + (fixed !== 1 ? 's' : '') + '.');
  else showToast('All requests already have correct coverage.');
}

function autoAssignCoverage(override) {
  const toAssign = ptoRequests.filter(r => r.status === 'Approved');
  if (toAssign.length === 0) { showError('No approved PTO requests to assign coverage for.'); return; }
  coverageAssignments = generateCoverageAssignments(ptoRequests, coverageAssignments, teamMembers, override, override, override);
  saveAll();
  renderAll();
  showToast('✅ Coverage auto-assigned.');
}

function updateAvailability(memberId, field, value) {
  teamMembers = teamMembers.map(m => {
    if (m.id !== memberId) return m;
    if (field === 'available') return { ...m, isCoverageAvailable: value, coverageLeaveStart: value ? '' : m.coverageLeaveStart, coverageLeaveEnd: value ? '' : m.coverageLeaveEnd };
    if (field === 'leaveStart') return { ...m, isCoverageAvailable: false, coverageLeaveStart: value };
    if (field === 'leaveEnd') return { ...m, isCoverageAvailable: false, coverageLeaveEnd: value };
    if (field === 'email') return { ...m, email: value.trim() };
    return m;
  });
  if (field !== 'email') coverageAssignments = replaceConflictingCoverers(ptoRequests, coverageAssignments, teamMembers);
  saveAll();
  if (field !== 'email') renderAll();
}

function changeMonth(delta) {
  calMonth += delta;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
}

