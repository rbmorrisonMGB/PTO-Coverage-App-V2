function exportPTOTrackerCSV() {
  const data = buildPTOTrackerData();
  const today = new Date();
  const curYear  = today.getFullYear();
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  let csv1 = 'PTO Yearly Summary ' + curYear + '\n';
  csv1 += 'Member,Manager,Vacation,Medical,Personal,Unpaid,Total\n';
  data.sort((a,b) => a.member.name.localeCompare(b.member.name)).forEach(({ member, yearly }) => {
    const total = yearly.Vacation + yearly.Medical + yearly.Personal + yearly.Unpaid;
    csv1 += `"${member.name}","${member.manager}",${yearly.Vacation},${yearly.Medical},${yearly.Personal},${yearly.Unpaid},${total}\n`;
  });

  const windowMonths = data[0]?.windowMonths || [];
  const monthHeaders = windowMonths.map(({ month, year }) => `"${monthNames[month]} ${year}"`).join(',');
