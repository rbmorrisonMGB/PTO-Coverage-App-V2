<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PTO Coverage Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --mgb-teal: #01828E;
    --mgb-teal-dark: #016b76;
    --mgb-teal-soft: #E1F5EE;
    --mgb-blue: #003A96;
    --mgb-blue-soft: #E6F1FB;
    --mgb-bone: #EAE7DD;
    --bg: #f4f2ee;
    --surface: #ffffff;
    --surface2: #f9f8f5;
    --border: #e0ddd5;
    --border2: #ccc9c0;
    --text: #0f0e0c;
    --text2: #4a4844;
    --text3: #888580;
    --accent: var(--mgb-teal);
    --accent-soft: var(--mgb-teal-soft);
    --accent2: #8b4513;
    --accent2-soft: #fdf0e8;
    --danger: #BC343E;
    --danger-soft: #FCEBEB;
    --info: var(--mgb-blue);
    --info-soft: var(--mgb-blue-soft);
    --pending: #854F0B;
    --pending-soft: #FAEEDA;
    --success: #085041;
    --success-soft: #E1F5EE;
    --radius: 10px;
    --radius-sm: 6px;
    --shadow: 0 1px 2px rgba(0,0,0,0.04), 0 3px 8px rgba(0,0,0,0.03);
    --shadow-lg: 0 4px 16px rgba(0,0,0,0.08), 0 12px 32px rgba(0,0,0,0.05);
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.5;
    font-size: 14px;
  }

  /* Header */
  .app-header {
    background: var(--mgb-teal);
    color: white;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .app-header-inner { display: flex; align-items: center; gap: 0.85rem; }
  .app-header-icon {
    width: 36px; height: 36px;
    background: rgba(255,255,255,0.15);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; flex-shrink: 0;
  }
  .app-header h1 { font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; color: white; }
  .app-header p { font-size: 0.72rem; color: rgba(255,255,255,0.65); margin-top: 0.1rem; }
  .app-header-badge {
    background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9);
    font-size: 0.72rem; font-weight: 500; padding: 0.25rem 0.75rem;
    border-radius: 999px; border: 1px solid rgba(255,255,255,0.2);
  }

  /* Stat bar */
  .stat-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex;
    overflow-x: auto;
  }
  .stat-item {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.6rem 1.5rem 0.6rem 0;
    margin-right: 1.5rem;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
  }
  .stat-item:last-child { border-right: none; margin-right: 0; }
  .stat-item-val { font-size: 1.4rem; font-weight: 700; line-height: 1; letter-spacing: -0.03em; }
  .stat-item-label { font-size: 0.72rem; color: var(--text3); line-height: 1.3; max-width: 80px; }
  .stat-teal { color: var(--mgb-teal); }
  .stat-amber { color: var(--pending); }
  .stat-blue { color: var(--mgb-blue); }
  .stat-gray { color: var(--text3); }

  /* Tabs */
  .tabs-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex;
    gap: 0;
    overflow-x: auto;
  }
  .tab-btn {
    background: none; border: none;
    border-bottom: 2px solid transparent;
    color: var(--text3);
    padding: 0.75rem 1.1rem;
    font-size: 0.82rem; font-weight: 500;
    cursor: pointer; white-space: nowrap;
    font-family: inherit; transition: all 0.15s;
  }
  .tab-btn:hover { color: var(--text); background: var(--bg); }
  .tab-btn.active { color: var(--mgb-teal); border-bottom-color: var(--mgb-teal); font-weight: 600; }

  /* Main layout */
  .app-body { max-width: 1200px; margin: 0 auto; padding: 1.25rem 2rem; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* Cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    box-shadow: var(--shadow);
    margin-bottom: 1rem;
  }
  .card-title {
    font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    margin-bottom: 1rem; color: var(--text3);
    display: flex; align-items: center; gap: 0.5rem;
  }
  .card-title .icon { font-size: 1rem; color: var(--mgb-teal); }

  /* Form */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; }
  .form-grid.cols3 { grid-template-columns: 1fr 1fr 1fr; }
  .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
  .form-group.full { grid-column: 1 / -1; }
  label { font-size: 0.72rem; font-weight: 500; color: var(--text3); text-transform: uppercase; letter-spacing: 0.05em; }
  input[type="text"], input[type="date"], select, textarea {
    font-family: inherit; font-size: 0.875rem; color: var(--text);
    background: var(--surface); border: 1px solid var(--border2);
    border-radius: var(--radius-sm); padding: 0.5rem 0.75rem;
    transition: border-color 0.15s, box-shadow 0.15s; width: 100%;
  }
  input:focus, select:focus { outline: none; border-color: var(--mgb-teal); box-shadow: 0 0 0 3px rgba(1,130,142,0.1); }
  input[type="checkbox"] { width: 15px; height: 15px; cursor: pointer; accent-color: var(--mgb-teal); }
  .checkbox-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--text2); }

  /* Buttons */
  .btn {
    font-family: inherit; font-size: 0.82rem; font-weight: 500;
    padding: 0.48rem 0.9rem; border-radius: var(--radius-sm);
    border: 1px solid transparent; cursor: pointer;
    transition: all 0.15s; display: inline-flex; align-items: center; gap: 0.4rem;
  }
  .btn-primary { background: var(--mgb-teal); color: white; border-color: var(--mgb-teal); }
  .btn-primary:hover { background: var(--mgb-teal-dark); }
  .btn-secondary { background: var(--surface); color: var(--text); border-color: var(--border2); }
  .btn-secondary:hover { background: var(--bg); border-color: var(--text3); }
  .btn-danger { background: var(--danger-soft); color: var(--danger); border-color: #f5c6c3; }
  .btn-danger:hover { background: #fce8e6; }
  .btn-sm { padding: 0.3rem 0.6rem; font-size: 0.78rem; }
  .btn-approve { background: var(--success-soft); color: var(--success); border-color: #9FE1CB; }
  .btn-approve:hover { background: #c4edd9; }
  .btn-reject { background: var(--danger-soft); color: var(--danger); border-color: #f5c6c3; }
  .btn-reject:hover { background: #fce8e6; }
  .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }

  /* Tables */
  .table-wrap { overflow-x: auto; border-radius: var(--radius-sm); border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  thead th {
    background: var(--surface2); padding: 0.6rem 0.9rem;
    text-align: left; font-weight: 500; color: var(--text3);
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border); white-space: nowrap;
  }
  tbody td { padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: middle; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: #f7f5f0; }
  .empty-row td { text-align: center; color: var(--text3); padding: 2.5rem; font-size: 0.875rem; }

  /* Badges */
  .badge {
    display: inline-flex; align-items: center;
    padding: 0.18rem 0.6rem; border-radius: 999px;
    font-size: 0.72rem; font-weight: 600; white-space: nowrap; letter-spacing: 0.02em;
  }
  .badge-pending { background: var(--pending-soft); color: var(--pending); }
  .badge-approved { background: var(--success-soft); color: var(--success); }
  .badge-rejected { background: var(--danger-soft); color: var(--danger); }
  .badge-override { background: #fdf0e8; color: #854F0B; }

  /* Score bars */
  .score-bar-wrap { display: flex; align-items: center; gap: 0.75rem; }
  .score-bar-bg { flex: 1; height: 5px; background: var(--border); border-radius: 999px; overflow: hidden; }
  .score-bar-fill { height: 100%; background: var(--mgb-teal); border-radius: 999px; transition: width 0.4s; }
  .score-val { font-family: 'DM Mono', monospace; font-size: 0.82rem; color: var(--text3); min-width: 36px; text-align: right; }

  /* Calendar */
  .calendar-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .calendar-month { font-size: 1.35rem; font-weight: 700; letter-spacing: -0.03em; color: var(--text); }
  .cal-table { width: 100%; border-collapse: separate; border-spacing: 2px; }
  .cal-table th { background: var(--mgb-teal); color: white; padding: 0.5rem 0.75rem; font-size: 0.75rem; text-align: center; font-weight: 500; letter-spacing: 0.04em; border-radius: 4px; }
  .cal-date-row td { padding: 0.35rem 0.5rem; font-size: 0.75rem; font-weight: 600; color: var(--text3); background: var(--surface2); border-radius: 4px; text-align: center; border: 1px solid var(--border); }
  .cal-body-row td { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 0.4rem; min-height: 60px; vertical-align: top; min-width: 80px; }
  .cal-body-row td.has-pto { background: #f0faf9; }
  .cal-body-row td.coverage-col { background: var(--surface2); min-width: 180px; }
  .cal-chip { display: inline-block; border-radius: 4px; padding: 1px 6px; font-size: 0.72rem; font-weight: 600; white-space: nowrap; color: #0f0e0c; margin-bottom: 2px; margin-right: 2px; }
  .cov-block { border: 1px solid var(--border); background: white; border-radius: 6px; padding: 0.4rem; margin-bottom: 0.35rem; }
  .cov-block-name { font-weight: 700; font-size: 0.82rem; margin-bottom: 0.25rem; color: var(--text); }
  .cov-row { display: flex; align-items: flex-start; gap: 0.4rem; margin-top: 0.15rem; font-size: 0.78rem; }
  .cov-pill { background: var(--mgb-teal-soft); color: #016b76; border-radius: 999px; padding: 1px 7px; font-size: 0.68rem; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
  .cal-open { color: var(--text3); font-size: 0.8rem; font-style: italic; }

  /* Availability admin */
  .manager-group { margin-bottom: 1.25rem; }
  .manager-label { font-size: 0.8rem; font-weight: 600; color: var(--text2); padding: 0.4rem 0; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
  .avail-row {
    display: grid; grid-template-columns: 200px 160px 1fr auto auto;
    gap: 0.6rem; align-items: center; padding: 0.55rem 0.75rem;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    margin-bottom: 0.35rem; background: var(--surface); transition: border-color 0.15s;
  }
  .avail-row:hover { border-color: var(--border2); }
  .avail-name { font-weight: 500; font-size: 0.875rem; display: flex; align-items: center; gap: 0.4rem; }
  .avail-status { font-size: 0.72rem; color: var(--text3); background: var(--surface2); border: 1px solid var(--border); border-radius: 999px; padding: 0.15rem 0.5rem; white-space: nowrap; }
  .avail-date-group { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; }
  .avail-date-group input { padding: 0.3rem 0.5rem; font-size: 0.8rem; width: 130px; }

  /* Two-col layout */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .two-col.asym { grid-template-columns: 1fr 1.5fr; }

  /* Import/Export */
  .import-box { border: 2px dashed var(--border2); border-radius: var(--radius); padding: 1.5rem; text-align: center; color: var(--text2); }
  .import-box:hover { border-color: var(--mgb-teal); background: var(--mgb-teal-soft); }

  /* Rules list */
  .rules-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .rules-list li { padding: 0.65rem 0.85rem; background: var(--surface2); border-left: 3px solid var(--mgb-teal); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; font-size: 0.875rem; color: var(--text2); }

  /* Responsive */
  @media (max-width: 768px) {
    .app-body { padding: 1rem; }
    .form-grid, .form-grid.cols3 { grid-template-columns: 1fr; }
    .two-col, .two-col.asym { grid-template-columns: 1fr; }
    .avail-row { grid-template-columns: 1fr; }
    .tabs-bar, .stat-bar { padding: 0 1rem; }
  }

  .error-banner { background: var(--danger-soft); border: 1px solid #f5c6c3; border-radius: var(--radius-sm); padding: 0.75rem 1rem; color: var(--danger); font-size: 0.875rem; margin-bottom: 1rem; }
  .info-banner { background: var(--info-soft); border: 1px solid #B5D4F4; border-radius: var(--radius-sm); padding: 0.75rem 1rem; color: var(--info); font-size: 0.875rem; margin-bottom: 1rem; }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
  .score-mode-select { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--text2); }
  .score-mode-select select { width: auto; padding: 0.3rem 0.6rem; }

  /* Modals */
  .modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4);
    z-index: 1000; align-items: center; justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: var(--surface); border-radius: var(--radius); padding: 1.5rem;
    box-shadow: var(--shadow-lg); width: 100%; max-width: 360px;
    border: 1px solid var(--border);
  }
  .modal-title { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--text); }
  .modal-sub { font-size: 0.8rem; color: var(--text3); margin-bottom: 1.25rem; }
  .modal-error { font-size: 0.8rem; color: var(--danger); margin-top: 0.5rem; min-height: 1.2em; }
  .modal-actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem; }
</style>
</head>
<body>

<header class="app-header">
  <div class="app-header-inner">
    <div class="app-header-icon">🗓</div>
    <div>
      <h1>PTO Coverage Manager</h1>
      <p>MGB Research Finance &middot; Team scheduling &amp; coverage</p>
    </div>
  </div>
  <div class="app-header-badge">2026</div>
</header>

<div class="stat-bar" id="stat-bar">
  <div class="stat-item"><div class="stat-item-val stat-teal" id="stat-active">—</div><div class="stat-item-label">Active requests</div></div>
  <div class="stat-item"><div class="stat-item-val stat-amber" id="stat-pending">—</div><div class="stat-item-label">Pending approval</div></div>
  <div class="stat-item"><div class="stat-item-val stat-blue" id="stat-approved">—</div><div class="stat-item-label">Approved this month</div></div>
  <div class="stat-item"><div class="stat-item-val stat-gray" id="stat-archived">—</div><div class="stat-item-label">Archived</div></div>
</div>

<nav class="tabs-bar">
  <button class="tab-btn active" data-tab="pto">PTO Requests</button>
  <button class="tab-btn" data-tab="calendar">Calendar</button>
  <button class="tab-btn" data-tab="rules">Coverage Rules</button>
  <button class="tab-btn" data-tab="score">Coverage Score</button>
  <button class="tab-btn" data-tab="admin">Settings / Admin</button>
</nav>

<!-- Edit Dates Modal -->
<div class="modal-overlay" id="edit-dates-modal">
  <div class="modal-box" style="max-width:480px;max-height:90vh;display:flex;flex-direction:column;overflow:hidden">
    <div class="modal-title">✏️ Edit PTO Dates</div>
    <div class="modal-sub" id="edit-dates-sub" style="font-size:0.8rem;color:var(--text3);margin-bottom:1rem;line-height:1.5"></div>
    <div style="overflow-y:auto;flex:1">
      <div class="form-grid" style="margin-bottom:1rem">
        <div class="form-group">
          <label>New start date</label>
          <input type="date" id="edit-start-date" onchange="previewEditDates()">
        </div>
        <div class="form-group">
          <label>New end date</label>
          <input type="date" id="edit-end-date" onchange="previewEditDates()">
        </div>
      </div>
      <div id="edit-dates-preview"></div>
    </div>
    <div class="modal-actions" style="flex-shrink:0;margin-top:1rem">
      <button class="btn btn-secondary" onclick="closeEditDatesModal()">Cancel</button>
      <button class="btn btn-primary" id="edit-dates-confirm-btn" onclick="confirmEditDates()" disabled>Confirm date change</button>
    </div>
  </div>
</div>

<!-- Password Modal -->
<div class="modal-overlay" id="pw-modal">
  <div class="modal-box">
    <div class="modal-title">🔒 Admin Authorization Required</div>
    <div class="modal-sub">Enter the admin password to clear all PTO requests and coverage assignments.</div>
    <div class="form-group">
      <label for="pw-input">Password</label>
      <input type="password" id="pw-input" placeholder="Enter password" onkeydown="if(event.key==='Enter')confirmClearAll()">
    </div>
    <div class="modal-error" id="pw-error"></div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closePwModal()">Cancel</button>
      <button class="btn btn-danger" onclick="confirmClearAll()">Clear All</button>
    </div>
  </div>
</div>

<!-- Reassign Coverage Modal -->
<div class="modal-overlay" id="reassign-modal">
  <div class="modal-box" style="max-width:480px">
    <div class="modal-title">🔄 Reassign Coverage</div>
    <div id="reassign-pto-info" style="font-size:0.82rem;color:var(--text2);background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.6rem 0.85rem;margin-bottom:1rem;line-height:1.6"></div>
    <div class="form-grid" style="margin-bottom:0.85rem">
      <div class="form-group">
        <label for="reassign-primary">Primary Coverer</label>
        <select id="reassign-primary" onchange="validateReassign()"></select>
      </div>
      <div class="form-group">
        <label for="reassign-secondary">Secondary Coverer</label>
        <select id="reassign-secondary" onchange="validateReassign()"></select>
      </div>
    </div>
    <div id="reassign-warnings" style="display:none;margin-bottom:0.85rem">
      <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:var(--radius-sm);padding:0.75rem 1rem;font-size:0.82rem;color:#92400e">
        <strong>⚠️ Rule violations detected:</strong>
        <ul id="reassign-warning-list" style="margin:0.4rem 0 0 1rem;padding:0;line-height:1.7"></ul>
      </div>
      <label class="checkbox-row" style="margin-top:0.65rem;font-size:0.875rem;color:var(--text2)">
        <input type="checkbox" id="reassign-override" onchange="validateReassign()">
        I understand the violations — override and save anyway
      </label>
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeReassignModal()">Cancel</button>
      <button class="btn btn-primary" id="reassign-save-btn" onclick="saveReassign()" disabled>Save Assignment</button>
    </div>
  </div>
</div>

<!-- Invite Preview Modal -->
<div class="modal-overlay" id="invite-modal">
  <div class="modal-box" style="max-width:600px;max-height:90vh;display:flex;flex-direction:column;overflow:hidden">
    <div class="modal-title">✉ Outlook Invite Preview</div>
    <div style="font-size:0.8rem;color:var(--text3);margin-bottom:0.75rem">Review the details below, then download the files. <strong style="color:var(--text)">In Outlook: open the .ics → click <em>Calendar</em> (top ribbon) to add it → open the event → click <em>Edit</em> → add attendees → click <em>Send</em>. This makes you the organizer.</strong></div>
    <div id="invite-content" style="overflow-y:auto;flex:1;padding-right:4px"></div>
    <div class="modal-actions" style="margin-top:1rem;flex-shrink:0">
      <button class="btn btn-secondary" onclick="closeInviteModal()">Cancel</button>
      <button class="btn btn-primary" id="invite-outlook-btn" onclick="launchOutlook()" style="background:#0078d4;border-color:#0078d4">📅 Download Calendar Invite (.ics)</button>
    </div>
  </div>
</div>
<!-- Confirm Modal -->
<div class="modal-overlay" id="confirm-modal">
  <div class="modal-box">
    <div class="modal-title" id="confirm-title">Confirm</div>
    <div class="modal-sub" id="confirm-msg"></div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="confirmResolve(false)">Cancel</button>
      <button class="btn btn-danger" onclick="confirmResolve(true)" id="confirm-ok-btn">Confirm</button>
    </div>
  </div>
</div>

<!-- Toast Notification -->
<div id="toast" style="
  position:fixed; bottom:1.5rem; left:50%; transform:translateX(-50%) translateY(80px);
  background:#1a1917; color:white; padding:0.75rem 1.25rem; border-radius:8px;
  font-size:0.875rem; font-weight:500; z-index:2000; transition:transform 0.25s ease;
  max-width:480px; text-align:center; box-shadow:0 4px 16px rgba(0,0,0,0.2);
  pointer-events:none;
"></div>

<div class="app-body">
  <div id="error-banner" class="error-banner" style="display:none"></div>

  <!-- PTO REQUESTS TAB -->
  <div class="tab-panel active" id="tab-pto">
    <div class="two-col">
      <div class="card">
