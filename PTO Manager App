function handleImport(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('import-status');
  if (file.name.toLowerCase().endsWith('.json')) {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const parsed = JSON.parse(e.target.result);
        if (Array.isArray(parsed.teamMembers)) teamMembers = parsed.teamMembers.map(m => ({ ...m, isCoverageAvailable: m.isCoverageAvailable !== false, coverageLeaveStart: m.coverageLeaveStart || '', coverageLeaveEnd: m.coverageLeaveEnd || '' }));
        if (Array.isArray(parsed.ptoRequests)) { ptoRequests = parsed.ptoRequests; nextPtoId = ptoRequests.reduce((max, r) => Math.max(max, r.id), 0) + 1; }
        if (Array.isArray(parsed.coverageAssignments)) { coverageAssignments = replaceConflictingCoverers(ptoRequests, parsed.coverageAssignments, teamMembers); nextCovId = coverageAssignments.reduce((max, a) => Math.max(max, a.id), 0) + 1; }
        status.textContent = '✅ JSON imported successfully.'; status.style.color = 'var(--accent)';
        saveAll(); renderAll();
      } catch(err) { status.textContent = '❌ Invalid JSON file.'; status.style.color = 'var(--danger)'; }
    };
    reader.readAsText(file);
  } else {
    status.textContent = '⚠️ Only JSON import supported in this version.';
    status.style.color = 'var(--pending)';
  }
  input.value = '';
}

