let _invitePtoId = null;
let _inviteMailtoUrl = null;
let _inviteFileName = null;
let _inviteReminderUrl = null;
let _inviteReminderFileName = null;

function splitDepartmentsForInvite(departments, primary, secondary) {
  if (!departments || departments.length === 0) {
    return { assign: { [primary]: [], ...(secondary ? { [secondary]: [] } : {}) }, totals: { [primary]: 0, ...(secondary ? { [secondary]: 0 } : {}) } };
  }
  if (!secondary) {
    return { assign: { [primary]: departments }, totals: { [primary]: departments.reduce((s, d) => s + d.complexity, 0) } };
  }
  const sorted = [...departments].sort((a, b) => b.complexity - a.complexity);
  const assign = { [primary]: [], [secondary]: [] };
  const totals = { [primary]: 0, [secondary]: 0 };
  sorted.forEach(dept => {
    const ps = totals[primary] * 1000 + assign[primary].length;
    const ss = totals[secondary] * 1000 + assign[secondary].length;
    const lower = ps <= ss ? primary : secondary;
    assign[lower].push(dept);
    totals[lower] += dept.complexity;
  });
  return { assign, totals };
}

function getFirstName(fullName) {
  if (!fullName) return '';
  // Handle "Last, First" format
  if (fullName.includes(',')) return fullName.split(',')[1].trim().split(/\s+/)[0];
  // Handle "First Last" or "First Middle Last" — everything except the last word
  const parts = fullName.trim().split(/\s+/);
  if (parts.length === 1) return parts[0];
  return parts.slice(0, -1).join(' ');
}

function openInviteModal(ptoReqId) {
  const req = reqById(ptoReqId);
  if (!req) return;
  _invitePtoId = ptoReqId;

  const member = memberById(req.memberId);
  const memberName = member?.name || 'Unknown';

  // Get coverers — guard against missing assignments
  const assignments = coverageAssignments.filter(a => a.ptoRequestId === ptoReqId);
  const primaryCoverer = assignments[0] ? memberById(assignments[0].covererId) : null;
  const secondaryCoverer = assignments[1] ? memberById(assignments[1].covererId) : null;

  // Only pass non-empty names to split function
  const primaryName = primaryCoverer?.name || null;
  const secondaryName = secondaryCoverer?.name || null;

  // Look up departments — two-pass: last+first match, then last-name-only fallback
  // App stores names as "First Last", DEPARTMENT_DATA keys are "Last, First"
  const nameParts = memberName.trim().split(/\s+/);
  const appLastName = nameParts[nameParts.length - 1].toLowerCase();
  const appFirstName = nameParts[0].toLowerCase();

  let deptKey = null;
  // Pass 1: match last name + first name
  for (const k of Object.keys(DEPARTMENT_DATA)) {
    const kParts = k.split(',');
    const kLast = kParts[0].trim().toLowerCase();
    const kFirst = kParts.length > 1 ? kParts[1].trim().toLowerCase() : '';
    const kFirstWord = kFirst.split(/\s+/)[0];
    if (kLast === appLastName && (kFirstWord === appFirstName || kFirst.startsWith(appFirstName))) {
      deptKey = k;
      break;
    }
  }
  // Pass 2: last name only (handles first-name spelling variations e.g. Alergia/Alegria)
  if (!deptKey) {
    const lastMatches = Object.keys(DEPARTMENT_DATA).filter(k =>
      k.split(',')[0].trim().toLowerCase() === appLastName
    );
    if (lastMatches.length === 1) deptKey = lastMatches[0];
  }

  const deptInfo = deptKey ? DEPARTMENT_DATA[deptKey] : null;
  const departments = deptInfo?.departments || [];

  // ── Email validation — block if required parties missing email ──
  const missingEmails = [];
  if (!member?.email) missingEmails.push(memberName + ' (person on PTO)');
  if (primaryCoverer && !primaryCoverer.email) missingEmails.push(primaryName + ' (Primary coverer)');
  if (secondaryCoverer && !secondaryCoverer.email) missingEmails.push(secondaryName + ' (Secondary coverer)');

  const inviteBtn = document.getElementById('invite-outlook-btn');
  if (missingEmails.length > 0) {
    document.getElementById('invite-content').innerHTML = `
      <div style="background:var(--danger-soft);border:1px solid #f5c6c3;border-radius:var(--radius-sm);padding:0.85rem 1rem;font-size:0.875rem;color:var(--danger)">
        <strong>⚠️ Missing email addresses</strong>
        <p style="margin-top:0.4rem;font-size:0.82rem">The following people are missing email addresses. Please add them in <strong>Settings/Admin</strong> before sending the invite:</p>
        <ul style="margin:0.5rem 0 0 1.2rem;font-size:0.82rem;line-height:1.8">
          ${missingEmails.map(n => `<li>${n}</li>`).join('')}
        </ul>
      </div>`;
    if (inviteBtn) inviteBtn.disabled = true;
    _inviteMailtoUrl = null;
    _inviteFileName = null;
    document.getElementById('invite-modal').classList.add('open');
    return;
  }
  if (inviteBtn) inviteBtn.disabled = false;
  const splitPrimary = primaryName || 'Unassigned Primary';
  const splitSecondary = secondaryName || null;
  const { assign, totals } = splitDepartmentsForInvite(departments, splitPrimary, splitSecondary);

  // Managers — deduplicated
  const managerSet = new Set();
  if (member?.manager) managerSet.add(member.manager);
  if (primaryCoverer?.manager) managerSet.add(primaryCoverer.manager);
  if (secondaryCoverer?.manager) managerSet.add(secondaryCoverer.manager);
  const managers = Array.from(managerSet).filter(Boolean);

  // Format dates
  const fmtDate = ds => { const d = new Date(ds + 'T00:00:00'); return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' }); };
  const startFmt = fmtDate(req.startDate);
  const endFmt = fmtDate(req.endDate);
  const firstName = getFirstName(memberName);
  // lastName: for "Last, First" → before comma; for "First Last" → last word
  const lastName = memberName.includes(',')
    ? memberName.split(',')[0].trim()
    : memberName.trim().split(/\s+/).pop();

  // Greeting using coverer first names
  const covererFirstNames = [primaryCoverer, secondaryCoverer].filter(Boolean).map(m => getFirstName(m.name));
  const greeting = covererFirstNames.length > 0 ? `Good morning ${covererFirstNames.join(' and ')},` : 'Good morning,';

  // Build department rows HTML — safe array access
  let deptRowsHtml = '';
  let daSplitHtml = '';   // extra DA section appended below the table
  let daSplitPlain = '';  // plain-text version for ICS DESCRIPTION

  if (departments.length === 0) {
    deptRowsHtml = `<tr><td colspan="2" style="font-style:italic;color:var(--text3);text-align:center;padding:0.75rem">No departments on file for this member.</td></tr>`;
  } else if (!primaryName) {
    deptRowsHtml = `<tr><td colspan="2" style="font-style:italic;color:var(--text3);text-align:center;padding:0.75rem">No coverage assigned yet — auto-assign coverage first.</td></tr>`;
  } else {
    const primaryDepts = (assign[splitPrimary] || []).map(d => ({ ...d, coverer: primaryName, role: 'Primary' }));
    const secondaryDepts = splitSecondary ? (assign[splitSecondary] || []).map(d => ({ ...d, coverer: secondaryName, role: 'Secondary' })) : [];
    const allDepts = [...primaryDepts, ...secondaryDepts];
    allDepts.forEach((d, idx) => {
      const rowBg = idx % 2 === 0 ? 'background:#ffffff' : 'background:#dce8f0';
      const nameParts = d.coverer.trim().split(/\s+/);
      const covererDisplay = nameParts.length > 1
        ? nameParts[nameParts.length - 1] + ', ' + nameParts.slice(0, -1).join(' ')
        : d.coverer;
      deptRowsHtml += `<tr style="${rowBg}">
        <td style="padding:7px 12px;border:0.5px solid #b8c8d4;font-size:13.5px;color:#0f0e0c">${d.name}</td>
        <td style="padding:7px 12px;border:0.5px solid #b8c8d4;font-size:13.5px;font-weight:600;color:#0a0908;white-space:nowrap">${covererDisplay}</td>
      </tr>`;

      // Check for DA split for this member + dept combination
      const daSplitKey = `${memberName}|${d.name.split(' - ')[0].trim()}`;
      const daSplit = DA_SPLITS[daSplitKey];
      if (daSplit) {
        // HTML version
        const groupsHtml = daSplit.groups.map((g, gi) => `
          <div style="margin-bottom:${gi < daSplit.groups.length - 1 ? '10px' : '0'}">
            <div style="font-size:12.5px;font-weight:600;color:#0a0908;margin-bottom:4px">${g.role}:</div>
            ${g.das.map(da => `<div style="font-size:12px;color:#0f0e0c;padding:1px 0 1px 12px">• ${da}</div>`).join('')}
          </div>`).join('');
        daSplitHtml += `
          <div style="margin-top:10px;padding:10px 12px;background:#f0faf9;border:0.5px solid #b3dfd1;border-radius:6px;font-family:Calibri,Arial,sans-serif">
            <div style="font-size:12px;font-weight:600;color:#01828E;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.04em">${daSplit.label}</div>
            <div style="font-size:12px;color:#4a4844;margin-bottom:8px">${daSplit.note}</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">${groupsHtml}</div>
          </div>`;

        // Plain text version for ICS
        daSplitPlain += `\n${daSplit.label}\n${daSplit.note}\n` +
          daSplit.groups.map(g => `${g.role}:\n${g.das.map(da => `  - ${da}`).join('\n')}`).join('\n\n');
      }
    });
  }

  // Complexity totals — safe access
  const primaryTotal = totals[splitPrimary] || 0;
  const secondaryTotal = splitSecondary ? (totals[splitSecondary] || 0) : 0;
  const primaryDeptCount = (assign[splitPrimary] || []).length;
  const secondaryDeptCount = splitSecondary ? (assign[splitSecondary] || []).length : 0;

  // Render modal content
  document.getElementById('invite-content').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;margin-bottom:0.85rem">
      <div style="background:#e8f5f0;border:1px solid #b3dfd1;border-radius:var(--radius-sm);padding:0.6rem 0.85rem">
        <div style="font-size:0.72rem;color:var(--text2);margin-bottom:2px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em">Primary</div>
        <div style="font-size:0.875rem;font-weight:600;color:var(--text)">${primaryName || '— Not assigned —'}</div>
        <div style="font-size:0.75rem;color:var(--text2)">${primaryTotal} complexity pts · ${primaryDeptCount} dept${primaryDeptCount !== 1 ? 's' : ''}</div>
      </div>
      <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:var(--radius-sm);padding:0.6rem 0.85rem">
        <div style="font-size:0.72rem;color:var(--text2);margin-bottom:2px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em">Secondary</div>
        <div style="font-size:0.875rem;font-weight:600;color:var(--text)">${secondaryName || '— Not assigned —'}</div>
        <div style="font-size:0.75rem;color:var(--text2)">${secondaryTotal} complexity pts · ${secondaryDeptCount} dept${secondaryDeptCount !== 1 ? 's' : ''}</div>
      </div>
    </div>
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.75rem 1rem;margin-bottom:0.85rem;font-size:0.82rem;line-height:1.7">
      <div style="display:grid;grid-template-columns:80px 1fr;gap:4px 8px;margin-bottom:6px">
        <span style="font-weight:600;color:var(--text2)">Title:</span>
        <span>${firstName} ${lastName} PTO ${startFmt} – ${endFmt}</span>
        <span style="font-weight:600;color:var(--text2)">Required:</span>
        <span>${[memberName, primaryName, secondaryName].filter(Boolean).map(n => {
          const m = teamMembers.find(tm => tm.name === n);
          return m?.email ? `${n} <span style="color:var(--text3);font-size:0.75rem">&lt;${m.email}&gt;</span>` : n;
        }).join(' · ')}</span>
        <span style="font-weight:600;color:var(--text2)">Optional:</span>
        <span>${(() => {
          const optList = managers.map(n => {
            const email = MANAGER_EMAILS[n] || teamMembers.find(tm => tm.name === n)?.email || '';
            return email ? `${n} <span style="color:var(--text3);font-size:0.75rem">&lt;${email}&gt;</span>` : `${n} <span style="color:var(--text3);font-size:0.75rem">(no email)</span>`;
          });
          // Add Juliana if Harris is involved
          const harrisInvolved = managers.includes('Harris, Alanna') ||
            member?.manager === 'Harris, Alanna' ||
            primaryCoverer?.manager === 'Harris, Alanna' ||
            secondaryCoverer?.manager === 'Harris, Alanna';
          if (harrisInvolved) {
            const juliana = teamMembers.find(m => m.name === 'Juliana McWilliams');
            if (juliana) optList.push(`Juliana McWilliams <span style="color:var(--text3);font-size:0.75rem">&lt;${juliana.email || 'no email'}&gt;</span>`);
          }
          return optList.join(' · ') || '—';
        })()}</span>
        <span style="font-weight:600;color:var(--text2)">Dates:</span>
        <span>${req.startDate} – ${req.endDate} (All day)</span>
      </div>
      <hr style="border:none;border-top:0.5px solid var(--border);margin:8px 0">
      <div style="font-size:13.5px;line-height:1.75;color:#0f0e0c;margin-bottom:10px">${greeting}</div>
      <div style="font-size:13.5px;line-height:1.75;color:#0f0e0c;margin-bottom:14px">${firstName} has requested PTO from ${startFmt} through ${endFmt}. They will let you know if anything is due during this time.</div>
      <table style="width:100%;border-collapse:collapse;font-size:13.5px;table-layout:fixed">
        <tbody>${deptRowsHtml}</tbody>
      </table>
      ${daSplitHtml}
    </div>`;

  // Build ICS calendar file content

  // ICS date format: YYYYMMDD
  const icsDate = ds => ds.replace(/-/g, '');
  // End date for all-day event must be day AFTER in ICS format
  const icsEndDate = ds => {
    const d = new Date(ds + 'T00:00:00Z');
    d.setUTCDate(d.getUTCDate() + 1);
    return d.toISOString().split('T')[0].replace(/-/g, '');
  };
  const uid = `pto-${req.id}-${Date.now()}@pto-coverage-manager`;
  const now = new Date().toISOString().replace(/[-:]/g,'').split('.')[0] + 'Z';

  // Build attendee lines with real emails
  // Helper: look up manager member object by name string
  function findManagerMember(managerName) {
    return teamMembers.find(m => m.name === managerName || m.name.toLowerCase() === managerName.toLowerCase());
  }

  const toNames = [memberName, primaryName, secondaryName].filter(Boolean);
  const toEmails = [member?.email, primaryCoverer?.email, secondaryCoverer?.email].filter(Boolean);

  // Managers as optional — exclude Morrison since he is the ORGANIZER
  // Adding the organizer as an attendee causes Outlook to demote him to recipient
  const managerLines = managers
    .filter(mgrName => mgrName !== 'Morrison, Rob')
    .map(mgrName => {
      const mgrEmail = MANAGER_EMAILS[mgrName] || teamMembers.find(m => m.name === mgrName)?.email || '';
      const cn = mgrName.replace(/,\s*/g, ' ');
      const emailAddr = mgrEmail || 'noreply@pto-manager.local';
      return `ATTENDEE;ROLE=OPT-PARTICIPANT;PARTSTAT=NEEDS-ACTION;CN=${cn}:mailto:${emailAddr}`;
    });

  // When Harris, Alanna is any involved manager, also add Juliana McWilliams as optional
  const extraOptionalLines = [];
  const isHarrisInvolved = managers.includes('Harris, Alanna') ||
    member?.manager === 'Harris, Alanna' ||
    primaryCoverer?.manager === 'Harris, Alanna' ||
    secondaryCoverer?.manager === 'Harris, Alanna';

  if (isHarrisInvolved) {
    const juliana = teamMembers.find(m => m.name === 'Juliana McWilliams');
    if (juliana) {
      const julianaEmail = juliana.email || 'noreply@pto-manager.local';
      extraOptionalLines.push(
        `ATTENDEE;ROLE=OPT-PARTICIPANT;PARTSTAT=NEEDS-ACTION;CN=Juliana McWilliams:mailto:${julianaEmail}`
      );
    }
  }

  const attendeeLines = [
    ...toNames.map((n, i) => {
      const email = toEmails[i] || 'noreply@pto-manager.local';
      return `ATTENDEE;ROLE=REQ-PARTICIPANT;PARTSTAT=NEEDS-ACTION;RSVP=TRUE;CN=${n.replace(/,\s*/g,' ')}:mailto:${email}`;
    }),
    ...managerLines,
    ...extraOptionalLines
  ].join('\r\n');

  // Build ICS description — plain text fallback + HTML alternative for Outlook 365
  const toLastFirstICS = name => {
    if (!name) return '';
    if (name.includes(',')) return name;
    const parts = name.trim().split(/\s+/);
    if (parts.length < 2) return name;
    return parts[parts.length - 1] + ', ' + parts.slice(0, -1).join(' ');
  };
  const primaryDepts2 = primaryName ? (assign[splitPrimary] || []) : [];
  const secondaryDepts2 = secondaryName ? (assign[splitSecondary] || []) : [];
  const allDeptsICS = [
    ...primaryDepts2.map(d => ({ name: d.name, coverer: toLastFirstICS(primaryName) })),
    ...secondaryDepts2.map(d => ({ name: d.name, coverer: toLastFirstICS(secondaryName) }))
  ];

  // ── Document links ──
  const rolesUrl = 'https://partnershealthcare-my.sharepoint.com/:x:/r/personal/rbmorrison_mgb_org/Documents/Apps/PTO%20Calendar%20App/PTO%20%20Coverage%20Roles%20and%20Responsibilities%201.xlsx?d=wed2d61ac698d4bb880af3e3d8be46f0a&csf=1&web=1&e=oFzNZv';
  const sopUrl = 'https://partnershealthcare-my.sharepoint.com/:w:/r/personal/rbmorrison_mgb_org/Documents/Apps/PTO%20Calendar%20App/PTO%20SOP%205.11.2026.docx?d=we1fa11c9fe9f4b89a4e4860c63105cd0&csf=1&web=1&e=kaUxNz';
  const linksHtml = `<p style="margin:14px 0 4px;font-family:Calibri,Arial,sans-serif;font-size:13px;color:#4a4844">Reference documents:</p><p style="margin:0;font-family:Calibri,Arial,sans-serif;font-size:13px"><a href="${rolesUrl}" style="color:#003A96">PTO Coverage Roles and Responsibilities</a> &nbsp;|&nbsp; <a href="${sopUrl}" style="color:#003A96">PTO SOP</a></p>`;
  const linksPlain = `\nReference documents:\nPTO Coverage Roles and Responsibilities: ${rolesUrl}\nPTO SOP: ${sopUrl}`;

  // Plain text fallback (DESCRIPTION field)
  const deptLines = [
    greeting,
    '',
    `${firstName} has requested PTO from ${startFmt} through ${endFmt}. They will let you know if anything is due during this time.`,
    '',
    ...allDeptsICS.map(d => `${d.name}    ${d.coverer}`),
    ...(daSplitPlain ? [daSplitPlain] : []),
    '',
    'Reference documents:',
    `PTO Coverage Roles and Responsibilities: ${rolesUrl}`,
    `PTO SOP: ${sopUrl}`
  ].join('\n');

  // HTML alternative (X-ALT-DESC) — Outlook 365 renders this as formatted table
  const tableRows = allDeptsICS.map((d, idx) => {
    const bg = idx % 2 === 0 ? '#ffffff' : '#dce8f0';
    return `<tr><td style="padding:7px 12px;border:1px solid #b8c8d4;font-size:14px;color:#0f0e0c;background:${bg}">${d.name}</td><td style="padding:7px 12px;border:1px solid #b8c8d4;font-size:14px;font-weight:bold;color:#0a0908;background:${bg};white-space:nowrap">${d.coverer}</td></tr>`;
  }).join('');

  const htmlDescription = [
    '<html><body>',
    `<p style="font-family:Calibri,Arial,sans-serif;font-size:14px;color:#0f0e0c;margin:0 0 12px">${greeting}</p>`,
    `<p style="font-family:Calibri,Arial,sans-serif;font-size:14px;color:#0f0e0c;margin:0 0 16px">${firstName} has requested PTO from ${startFmt} through ${endFmt}. They will let you know if anything is due during this time.</p>`,
    `<table style="border-collapse:collapse;font-family:Calibri,Arial,sans-serif;width:100%">${tableRows}</table>`,
    daSplitHtml,
    linksHtml,
    '</body></html>'
  ].join('');

  // Escape special characters for ICS — order matters: \n and special chars first, backslash last
  const escapeICS = str => str
    .replace(/\n/g, '\\n')
    .replace(/;/g, '\\;')
    .replace(/,/g, '\\,');
  const plainDesc = `DESCRIPTION:${escapeICS(deptLines)}`;
  const htmlDesc = `X-ALT-DESC;FMTTYPE=text/html:${htmlDescription.replace(/\r?\n/g,' ')}`;

  const icsTitle = `${firstName} ${lastName} PTO ${startFmt} - ${endFmt}`;

  // ORGANIZER — Robert Morrison is the fixed organizer for all invites
  const organizerEmail = MANAGER_EMAILS['Morrison, Rob'] || 'rbmorrison@mgb.org';
  const organizerName = 'Robert Morrison';
  const organizerLine = `ORGANIZER;CN=${organizerName}:mailto:${organizerEmail}`;

  // ── Coverage ICS ──
  const icsContent = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'PRODID:-//PTO Coverage Manager//EN',
    'CALSCALE:GREGORIAN',
    'METHOD:PUBLISH',
    'BEGIN:VEVENT',
    `UID:${uid}`,
    `DTSTAMP:${now}`,
    `DTSTART;VALUE=DATE:${icsDate(req.startDate)}`,
    `DTEND;VALUE=DATE:${icsEndDate(req.endDate)}`,
    `SUMMARY:${icsTitle}`,
    plainDesc,
    htmlDesc,
    organizerLine,
    attendeeLines,
    'TRANSP:TRANSPARENT',
    'STATUS:CONFIRMED',
    'END:VEVENT',
    'END:VCALENDAR'
  ].join('\r\n');

  // ── Reminder ICS — 2 weeks before PTO start ──
  const reminderDate = (() => {
    const d = new Date(req.startDate + 'T00:00:00Z');
    d.setUTCDate(d.getUTCDate() - 14);
    // Move to Monday if weekend
    if (d.getUTCDay() === 0) d.setUTCDate(d.getUTCDate() + 1);
    if (d.getUTCDay() === 6) d.setUTCDate(d.getUTCDate() + 2);
    return d.toISOString().split('T')[0];
  })();
  const reminderEndDate = icsEndDate(reminderDate);
  const reminderUid = `reminder-${req.id}-${Date.now()}@pto-coverage-manager`;

  // Reminder optional recipients — manager + Juliana if Harris
  // Exclude Morrison since he is the ORGANIZER — adding organizer as attendee breaks Outlook
  const reminderManagerEmail = MANAGER_EMAILS[member?.manager] || '';
  const reminderManagerName = (member?.manager || '').replace(/,\s*/g, ' ');
  const reminderOptLines = [];
  if (reminderManagerEmail && member?.manager !== 'Morrison, Rob') {
    reminderOptLines.push(`ATTENDEE;ROLE=OPT-PARTICIPANT;PARTSTAT=NEEDS-ACTION;CN=${reminderManagerName}:mailto:${reminderManagerEmail}`);
  }
  if (member?.manager === 'Harris, Alanna') {
    const juliana = teamMembers.find(m => m.name === 'Juliana McWilliams');
    if (juliana?.email) {
      reminderOptLines.push(`ATTENDEE;ROLE=OPT-PARTICIPANT;PARTSTAT=NEEDS-ACTION;CN=Juliana McWilliams:mailto:${juliana.email}`);
    }
  }
  const reminderAttendeeLines = [
    `ATTENDEE;ROLE=REQ-PARTICIPANT;PARTSTAT=NEEDS-ACTION;RSVP=TRUE;CN=${memberName.replace(/,\s*/g,' ')}:mailto:${member?.email || 'noreply@pto-manager.local'}`,
    ...reminderOptLines
  ].join('\r\n');

  const reminderTitle = `Reminder: ${firstName} PTO on ${startFmt} — Please notify your departments`;
  const reminderPlainBody = `${reminderTitle}\n\nYour PTO begins in 2 weeks (${startFmt} – ${endFmt}). Please notify your departments as soon as possible so they are prepared.\n\nCoverage has been arranged. Please refer to the resources below for your coverage responsibilities and standard operating procedures.\n${linksPlain}`;
  const reminderHtmlBody = [
    '<html><body>',
    `<p style="font-family:Calibri,Arial,sans-serif;font-size:14px;font-weight:bold;color:#0a0908;margin:0 0 12px">${reminderTitle}</p>`,
    `<div style="background:#FAEEDA;border:1px solid #FAC775;border-radius:6px;padding:10px 14px;margin:0 0 12px;font-size:13px;color:#412402">`,
    `Your PTO begins in <strong>2 weeks</strong> (${startFmt} – ${endFmt}). Please notify your departments as soon as possible so they are prepared.</div>`,
    `<p style="font-family:Calibri,Arial,sans-serif;font-size:13px;color:#4a4844;margin:0 0 10px">Coverage has been arranged. Please refer to the resources below for your coverage responsibilities and standard operating procedures.</p>`,
    linksHtml,
    '</body></html>'
  ].join('');

  const reminderIcsContent = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'PRODID:-//PTO Coverage Manager//EN',
    'CALSCALE:GREGORIAN',
    'METHOD:PUBLISH',
    'BEGIN:VEVENT',
    `UID:${reminderUid}`,
    `DTSTAMP:${now}`,
    `DTSTART;VALUE=DATE:${icsDate(reminderDate)}`,
    `DTEND;VALUE=DATE:${reminderEndDate}`,
    `SUMMARY:${reminderTitle}`,
    `DESCRIPTION:${escapeICS(reminderPlainBody)}`,
    `X-ALT-DESC;FMTTYPE=text/html:${reminderHtmlBody.replace(/\r?\n/g,' ')}`,
    `ORGANIZER;CN=${organizerName}:mailto:${organizerEmail}`,
    reminderAttendeeLines,
    'TRANSP:TRANSPARENT',
    'STATUS:CONFIRMED',
    'END:VEVENT',
    'END:VCALENDAR'
  ].join('\r\n');

  _inviteMailtoUrl = icsContent;
  _inviteReminderUrl = reminderIcsContent;
  _inviteFileName = `${memberName.replace(/\s+/g,'_').replace(/,/g,'')}_PTO_Coverage_${req.startDate}.ics`;
  _inviteReminderFileName = `${memberName.replace(/\s+/g,'_').replace(/,/g,'')}_PTO_Reminder_${req.startDate}.ics`;

  document.getElementById('invite-modal').classList.add('open');
}

function closeInviteModal() {
  document.getElementById('invite-modal').classList.remove('open');
  _invitePtoId = null;
  _inviteMailtoUrl = null;
  _inviteFileName = null;
  _inviteReminderUrl = null;
  _inviteReminderFileName = null;
}

function launchOutlook() {
  function downloadBlob(content, filename) {
    const blob = new Blob([content], { type: 'text/calendar;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename;
    document.body.appendChild(a); a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  // Capture values locally BEFORE closeInviteModal nulls them out
  const coverageContent = _inviteMailtoUrl;
  const coverageFilename = _inviteFileName;
  const reminderContent = _inviteReminderUrl;
  const reminderFilename = _inviteReminderFileName;

  closeInviteModal();

  if (coverageContent && coverageFilename) {
    downloadBlob(coverageContent, coverageFilename);
  }
  if (reminderContent && reminderFilename) {
    setTimeout(() => downloadBlob(reminderContent, reminderFilename), 500);
    showToast('✅ 2 files downloading — Coverage invite + 2-week reminder. Open both in Outlook and send.');
  } else if (coverageContent) {
    showToast('✅ Calendar invite downloaded — double-click the .ics file to open in Outlook.');
  }
}

