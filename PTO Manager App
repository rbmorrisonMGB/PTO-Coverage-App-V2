  </tr></thead><tbody>`;

  weeks.forEach(week => {
    const ws = getMonStart(week[0]).toISOString().split('T')[0];

    // Date header row
    html += `<tr>`;
    html += `<td style="background:var(--surface2);padding:4px 10px;font-size:10px;font-weight:600;color:var(--text3);border:0.5px solid var(--border);text-transform:uppercase;letter-spacing:0.04em">Week of</td>`;
    week.forEach(d => {
