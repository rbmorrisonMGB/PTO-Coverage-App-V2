function approveReq(id) {
  const req = reqById(id);
  if (!req) return;
  const { allowed, week, reason } = canApproveRequest(req);
  if (!allowed) {
    if (reason === 'blackout') showError('⛔ Cannot approve: overlaps blackout window. Use override to force.');
    else showError(`⛔ Cannot approve: too many people off in week of ${week}. Use override to force.`);
    return;
  }
  req.status = 'Approved';
  // Always remove any existing assignments for this request before regenerating
  // This ensures stale single-coverer data never blocks a fresh 2-coverer assignment
  coverageAssignments = coverageAssignments.filter(a => a.ptoRequestId !== id);
  coverageAssignments = generateCoverageAssignments(ptoRequests, coverageAssignments, teamMembers, req.override || false, false, false);
  saveAll();
  renderAll();
  showToast('✅ Request approved and coverage assigned.');
}

function rejectReq(id) {
  const req = reqById(id);
  if (req) { req.status = 'Rejected'; saveAll(); renderAll(); showToast('Request rejected.'); }
}

function clearSinglePTO(id) {
  const req = reqById(id);
  if (!req) {
    showError('This request no longer exists.');
    renderAll();
    return;
  }
  // Guard: do not allow clearing archived requests (end date already passed)
  const today = new Date().toISOString().split('T')[0];
  if (req.endDate < today) {
    showError('Archived requests cannot be cleared. They are kept for historical record.');
    return;
  }
  const m = memberById(req.memberId);
  showConfirm(
    'Delete PTO Request',
    `Delete ${m?.name || 'Unknown'}'s PTO (${req.startDate} – ${req.endDate})? This will also remove associated coverage assignments.`,
    () => {
      // Re-check request still exists at time of confirmation
      if (!reqById(id)) { showError('Request was already removed.'); renderAll(); return; }
      ptoRequests = ptoRequests.filter(r => r.id !== id);
      coverageAssignments = coverageAssignments.filter(a => a.ptoRequestId !== id);
      saveAll();
      renderAll();
      showToast('✅ PTO request deleted.');
    }
  );
}

