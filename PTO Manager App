  archiveTbody.innerHTML = archivedHtml || '<tr class="empty-row"><td colspan="7">No archived coverage assignments yet.</td></tr>';
}

// ---- Calendar ----
let calYear = new Date().getUTCFullYear();
let calMonth = new Date().getUTCMonth();

function buildWeeks(year, month) {
  const first = new Date(Date.UTC(year, month, 1));
  const last = new Date(Date.UTC(year, month + 1, 0));
  const getMonStart = d => { const c = new Date(d); c.setUTCDate(c.getUTCDate() - ((c.getUTCDay() + 6) % 7)); c.setUTCHours(0,0,0,0); return c; };
  const weeks = [];
  let ws = getMonStart(first);
  const lastWs = getMonStart(last);
  while (ws <= lastWs) {
    const week = [];
    for (let i = 0; i < 5; i++) {
      const d = new Date(ws); d.setUTCDate(ws.getUTCDate() + i); week.push(d);
    }
    weeks.push(week);
    ws = new Date(ws); ws.setUTCDate(ws.getUTCDate() + 7);
  }
  return weeks;
}

function renderCalendar() {
  const label = new Date(Date.UTC(calYear, calMonth, 1)).toLocaleDateString('en-US', { year: 'numeric', month: 'long', timeZone: 'UTC' });
  document.getElementById('cal-month-label').textContent = label;

  function getMonStart(d) { const c = new Date(d); c.setUTCDate(c.getUTCDate() - ((c.getUTCDay() + 6) % 7)); return c; }

  // Helper: lighten a hex color for background tint
  function hexToRgb(hex) {
    const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return {r,g,b};
  }
  function tintColor(hex, opacity) {
    try {
      const {r,g,b} = hexToRgb(hex);
      return `rgba(${r},${g},${b},${opacity})`;
    } catch(e) { return '#f5f4f0'; }
  }

  const approvedReqs = ptoRequests.filter(r => r.status === 'Approved');

  // Build per-request data: which weekdays they're out + their coverers
  // Structure: { reqId: { req, member, color, ptoDates: Set, coverers: [] } }
  const reqData = {};
  approvedReqs.forEach(req => {
    const member = memberById(req.memberId);
    const color = member?.managerColor || '#cccccc';
    const ptoDates = new Set();
    const cur = toDate(req.startDate), end = toDate(req.endDate);
    const c = new Date(cur);
    while (c <= end) {
      const day = c.getUTCDay(), ds = c.toISOString().split('T')[0];
      if (day >= 1 && day <= 5 && !isFederalHoliday(ds)) ptoDates.add(ds);
      c.setUTCDate(c.getUTCDate() + 1);
    }
    // Get coverers for this request
    const coverers = coverageAssignments
      .filter(a => a.ptoRequestId === req.id)
      .map((a, idx) => ({ name: memberById(a.covererId)?.name || '?', role: idx === 0 ? 'Primary' : 'Secondary' }));
    reqData[req.id] = { req, member, color, ptoDates, coverers };
