document.addEventListener('DOMContentLoaded', function() {
  document.getElementById('pto-form').addEventListener('submit', e => {
    e.preventDefault();
    const memberId = parseInt(document.getElementById('f-member').value);
    const startDate = document.getElementById('f-start').value;
    const endDate = document.getElementById('f-end').value;
    const type = document.getElementById('f-type').value;
    const override = document.getElementById('f-override').checked;

    if (!startDate || !endDate || startDate > endDate) { showError('Invalid date range.'); return; }
    if (!override && isInBlackout(startDate, endDate)) {
      showError('⛔ These dates fall in a blackout period (week before 2/5, 6/5, or 10/5). Use Override or choose different dates.');
      return;
    }
    ptoRequests.push({ id: nextPtoId++, memberId, startDate, endDate, type, status: 'Pending', override });
    e.target.reset();
    document.getElementById('f-member').value = teamMembers[0]?.id;
    saveAll();
    renderAll();
    showToast('✅ PTO request created successfully.');
  });

  document.getElementById('pw-modal').addEventListener('click', function(e) {
    if (e.target === this) closePwModal();
  });
  document.getElementById('confirm-modal').addEventListener('click', function(e) {
    if (e.target === this) confirmResolve(false);
  });
  document.getElementById('invite-modal').addEventListener('click', function(e) {
    if (e.target === this) closeInviteModal();
  });

  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      if (btn.dataset.tab === 'calendar') renderCalendar();
      if (btn.dataset.tab === 'score') renderScores();
      if (btn.dataset.tab === 'admin') renderAvailAdmin();
    });
  });

  loadAll();
  healUnderCoveredRequests();
  renderMemberSelect();
  renderBlackoutDates();
  renderAll();
}); // end DOMContentLoaded
</script>
</body>
</html>
